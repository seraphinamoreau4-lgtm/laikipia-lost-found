# Environment
NODE_ENV=development

# Database (PostgreSQL)
# Local: postgresql://user:password@localhost:5432/laikipia_lost_found
# Render: postgresql://user:password@hostname:5432/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/laikipia_lost_found

# Server
PORT=5000
HOST=0.0.0.0

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# Anthropic AI
ANTHROPIC_API_KEY=your_anthropic_api_key

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=src/uploads

# Logging
LOG_LEVEL=info
